def task2():
    """
    Специальное преобразование массива:
    на первом месте - последний элемент,
    на втором - первый,
    на третьем - второй и т.д.
    """
    N = int(input())
    arr = list(map(int, input().split()))
    
    # Создаем новый массив по правилу
    result = []
    result.append(arr[-1])  # последний элемент
    for i in range(N - 1):
        result.append(arr[i])
        
    print(' '.join(map(str, result)))
