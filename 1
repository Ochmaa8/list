def task1():
    """
    Переворот массива чисел.
    Ввод: N, затем N чисел по одному на строке.
    Вывод: N чисел - перевернутый массив.
    """
    N = int(input())
    arr = []
    for _ in range(N):
        arr.append(int(input()))
    
    # Разворачиваем массив
    reversed_arr = arr[::-1]
    
    print(' '.join(map(str, reversed_arr)))
